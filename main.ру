# ========== ОБРАБОТКА ВОПРОСОВ ==========
@dp.message(ChatStates.waiting_for_message)
async def process_question(message: types.Message, state: FSMContext):
    user_id = message.from_user.id
    question = message.text
    
    if len(question) < 2:
        await message.answer("❌ Слишком короткий вопрос. Напишите подробнее:")
        return
    
    wait_msg = await message.answer("⏳ GigaChat думает... Подождите 5-10 секунд")
    
    # Формируем сообщение для GigaChat
    messages = [
        {"role": "system", "content": "Ты полезный ассистент. Отвечай на русском языке, подробно и по делу."},
        {"role": "user", "content": question}
    ]
    
    # Отправляем запрос
    answer = await gigachat.chat_completion(messages)
    
    await wait_msg.delete()
    
    if answer:
        # Разбиваем длинный ответ на части (Telegram лимит 4096 символов)
        if len(answer) > 4000:
            parts = [answer[i:i+4000] for i in range(0, len(answer), 4000)]
            for i, part in enumerate(parts):
                if i == 0:
                    await message.answer(f"💬 **Ответ GigaChat:**\n\n{part}", parse_mode="Markdown")
                else:
                    await message.answer(part)
        else:
            await message.answer(f"💬 **Ответ GigaChat:**\n\n{answer}", parse_mode="Markdown")
    else:
        await message.answer(
            "❌ Не удалось получить ответ от GigaChat.\n"
            "Попробуйте позже или задайте другой вопрос.",
            reply_markup=get_main_keyboard(user_id)
        )
    
    await state.clear()

